---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title }}</title>
  <subtitle>Notes on health product design.</subtitle>
  <link href="{{ site.url }}/feed.xml" rel="self"/>
  <link href="{{ site.url }}/"/>
  <id>{{ site.url }}/</id>
  <updated>{% if collections.blog.first %}{{ collections.blog.first.date | date: "%Y-%m-%dT%H:%M:%SZ" }}{% else %}{{ 'now' | date: "%Y-%m-%dT%H:%M:%SZ" }}{% endif %}</updated>
  <author>
    <name>{{ site.title }}</name>
    <email>hi@olibatstone.com</email>
  </author>
  {% for post in collections.blog %}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ site.url }}{{ post.url }}"/>
    <id>{{ site.url }}{{ post.url }}</id>
    <updated>{{ post.date | date: "%Y-%m-%dT%H:%M:%SZ" }}</updated>
    <summary>{{ post.data.description }}</summary>
  </entry>
  {% endfor %}
</feed>
